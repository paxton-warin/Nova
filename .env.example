PORT=3000
DATABASE_PATH=./data/nova-browser.db
SESSION_SECRET=OWIERJGKFDUJEHRNTYGJKVJHDENRJTGKJBHVNDSMERNTBGBJNMHGNTRBNFHVBNGFTRDJFHGBNTREDFG
MASTER_ADMIN_USERNAME=admin
MASTER_ADMIN_PASSWORD=password
MASTER_ADMIN_TOTP_SECRET=JSDNFKEWIHJBFSNDKFHBJESNFD
ENABLE_ERUDA_BY_DEFAULT=false
LIBCURL_TRANSPORT_PATH=/libcurl-transport-wrapper.mjs
WISP_PATH=/wisp/
# If CloudFront/origin strips Host, pass the public hostname/proto via X-Public-Host and X-Public-Proto
# from your CDN/proxy so Nova can still generate the correct public wss://.../wisp/ URL.
TRUST_PROXY=0
SESSION_COOKIE_SECURE=false
# lax | strict | none — use none + secure true for UI/API on different hosts (with CORS_ALLOW_ORIGINS + VITE_API_BASE_URL).
SESSION_COOKIE_SAMESITE=lax
# Comma-separated browser origins allowed to call the API with credentials (e.g. https://d123.cloudfront.net).
# CORS_ALLOW_ORIGINS=

# Frontend build (optional): npm run build in ./frontend with VITE_API_BASE_URL=https://api.example.com
# when HTML/JS is on a CDN but the Node server serves /api only.